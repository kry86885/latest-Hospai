{
  "name": "hospai-frontend",
  "private": true,
  "version": "1.0.0",
  "description": "Keppler Healthcare frontend web app",
  "author": "Keppler Healthcare",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:payments": "vitest run src/lib/razorpay.test.ts src/pages/RazorpayFlows.test.tsx src/pages/BillingPage.test.tsx src/pages/OpPage.test.tsx src/pages/RegistrationDeskPage.test.tsx",
    "test:ui": "vitest --ui",
    "test:e2e": "NODE_OPTIONS='--unhandled-rejections=warn' E2E_BASE_URL=${E2E_BASE_URL:-http://localhost:5173} jest --config ./jest.config.cjs",
    "test:e2e:headed": "NODE_OPTIONS='--unhandled-rejections=warn' HEADLESS=false E2E_BASE_URL=${E2E_BASE_URL:-http://localhost:5173} jest --config ./jest.config.cjs",
    "test:e2e:artifacts": "NODE_OPTIONS='--unhandled-rejections=warn' E2E_RUN_ID=latest E2E_BASE_URL=${E2E_BASE_URL:-http://localhost:5173} jest --config ./jest.config.cjs",
    "test:e2e:video": "node ./tests/e2e/make-video.cjs ./tests/e2e/artifacts/latest ./tests/e2e/artifacts/latest/e2e-run.mp4"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.1",
    "jest": "^29.7.0",
    "jest-puppeteer": "^10.1.0",
    "jsdom": "^28.0.0",
    "puppeteer": "^24.5.0",
    "typescript": "^5.8.2",
    "vite": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
