# =========================
# HospAI Backend
# =========================

# Server
PORT=5001
CORS_ALLOWED_ORIGINS=https://app.hospai.ai,https://staging-app.hospai.ai,http://localhost:5173,http://127.0.0.1:5173

# Session auth
SESSION_COOKIE_NAME=hospai_session
SESSION_TTL_HOURS=12
SESSION_PEPPER=change-this-to-a-long-random-secret
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax

# =========================
# /admin Separate Route Auth
# =========================
# REQUIRED to enable /admin login challenge.
ADMIN_ROUTE_PASSWORD=change-this-admin-route-password

# Optional overrides
ADMIN_ROUTE_AUTH_COOKIE_NAME=hospai_admin_route_auth
ADMIN_ROUTE_AUTH_TTL_SECONDS=3600
ADMIN_ROUTE_AUTH_SECRET=change-this-admin-route-cookie-secret

# =========================
# Database
# =========================
# Use sqlite locally
DB_ENGINE=sqlite
DB_PATH=./healthcare.db

# For postgres, set these and remove/ignore DB_PATH
# DB_ENGINE=postgres
# DATABASE_URL=postgresql://postgres:rahul@123@192.168.0.102:5432/hospai

# =========================
# OCR / AI
# =========================
# Set one of these keys if using OCR LLM integration
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# =========================
# Object Storage (Optional)
# =========================
# If blank, app falls back to local uploads/
BUCKET_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_ENDPOINT_URL=

# =========================
# Frontend (set in frontend/.env if needed)
# =========================
# VITE_API_BASE=http://localhost:5001
# VITE_SYMPTOM_API_BASE=http://localhost:5002

# =========================
# Static Marketing Site
# =========================
# Login/register pages redirect to this URL after submit.
VITE_APP_URL=http://localhost:5173

# =========================
# Razorpay (Backend)
# =========================
# Use test keys in staging/dev and live keys in production.
# Example:
# RAZORPAY_KEY_ID=rzp_live_xxxxxxx
# RAZORPAY_KEY_SECRET=4r5xxxxxxxxxxxxxxxxxxx3t
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
